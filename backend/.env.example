DATABASE_URL="postgresql://erp_user:erp_password@localhost:5432/erp_invoicing"
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-in-production
DEMO_USER_PASSWORD=demo
# Set to false in production so API requires JWT (UI login). Keep true for README curl examples.
ALLOW_HEADER_AUTH=true
# Required header for creating tenants via POST /api/tenants
ADMIN_API_KEY=demo-admin-key
